<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= botName %> — Site de Connexion</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="bg-glow"></div>

  <div class="container">
    <!-- Header -->
    <div class="header">
      <img src="<%= menuImage %>" alt="Menu" class="bot-image" onerror="this.style.display='none'">
      <h1 class="bot-name">🤖 <%= botName %></h1>
      <p class="dev-name">by <%= devName %></p>
      <div class="session-badge">
        <span class="dot"></span>
        <span><%= sessions %>/<%= maxSessions %> sessions actives</span>
      </div>
    </div>

    <!-- Card principale -->
    <div class="card">
      <h2>📱 Connecter WhatsApp</h2>
      <p class="subtitle">Entre ton numéro avec le code pays pour obtenir ton code de jumelage</p>

      <form id="pairForm">
        <div class="input-group">
          <span class="flag">🌍</span>
          <input
            type="tel"
            id="number"
            placeholder="Ex: 242065121108"
            maxlength="15"
            autocomplete="off"
            inputmode="numeric"
          >
        </div>
        <p class="hint">⚠️ Inclure le code pays sans le + (ex: <strong>242</strong>XXXXXXXX)</p>
        <button id="pairBtn" type="submit">📲 Obtenir mon code</button>
      </form>

      <!-- Résultat -->
      <div id="result" style="display:none;" class="result"></div>

      <!-- Affichage du code -->
      <div id="codeDisplay" style="display:none;" class="code-box">
        <p class="code-label">🔑 Ton code de jumelage :</p>
        <div class="code-value" id="codeValue"></div>
        <button id="copyBtn" class="copy-btn">📋 Copier le code</button>
      </div>

      <!-- Étapes -->
      <div id="steps" style="display:none;" class="steps-box">
        <h3>📋 Comment entrer le code dans WhatsApp :</h3>
        <ol>
          <li>Ouvre <strong>WhatsApp</strong> sur ton téléphone</li>
          <li>Appuie sur les <strong>3 points</strong> (menu) en haut à droite</li>
          <li>Va dans <strong>Appareils liés</strong></li>
          <li>Appuie sur <strong>Lier un appareil</strong></li>
          <li>Choisis <strong>"Lier avec un numéro de téléphone"</strong> (pas le QR)</li>
          <li>Entre le code <strong><span id="codeInSteps"></span></strong> affiché ci-dessus</li>
          <li>✅ Le bot se connecte automatiquement !</li>
        </ol>
        <div class="warning-box">
          ⏱️ Le code expire dans <strong>60 secondes</strong> — entre-le rapidement !
        </div>
      </div>
    </div>

    <!-- Liens sociaux -->
    <div class="social-links">
      <% if (channelLink) { %><a href="<%= channelLink %>" target="_blank" class="social-btn">📢 Canal</a><% } %>
      <% if (groupLink) { %><a href="<%= groupLink %>" target="_blank" class="social-btn">👥 Groupe</a><% } %>
      <% if (telegram) { %><a href="<%= telegram %>" target="_blank" class="social-btn">✈️ Telegram</a><% } %>
    </div>

    <p class="footer">© 2025 <%= devName %> • Tous droits réservés</p>
  </div>

  <script>
    // Passer le code aux étapes aussi
    const origUpdate = window.__updateCode;
  </script>
  <script src="/app.js"></script>
  <script>
    // Sync code dans les étapes
    const codeInSteps = document.getElementById('codeInSteps');
    const codeValue = document.getElementById('codeValue');
    const observer = new MutationObserver(() => {
      if (codeInSteps) codeInSteps.textContent = codeValue.textContent;
    });
    observer.observe(codeValue, { childList: true, characterData: true, subtree: true });
  </script>
</body>
</html>
