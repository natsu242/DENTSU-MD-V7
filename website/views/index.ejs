<!DOCTYPE html>
<html lang="fr" id="htmlRoot">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= botName %> — Connection Site</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="bg-glow"></div>

  <!-- ═══ SÉLECTION DE LANGUE ═══ -->
  <div id="langOverlay" class="lang-overlay">
    <div class="lang-card">
      <img src="<%= menuImage %>" alt="Bot" class="lang-bot-image" onerror="this.style.display='none'">
      <h1 class="lang-title">🤖 <%= botName %></h1>
      <p class="lang-subtitle">by <%= devName %></p>
      <div class="lang-flags-grid">
        <button class="flag-btn" onclick="setLang('fr')"><img src="https://flagcdn.com/48x36/fr.png" alt="Français"></button>
        <button class="flag-btn" onclick="setLang('en')"><img src="https://flagcdn.com/48x36/us.png" alt="English"></button>
        <button class="flag-btn" onclick="setLang('es')"><img src="https://flagcdn.com/48x36/es.png" alt="Español"></button>
        <button class="flag-btn" onclick="setLang('zh')"><img src="https://flagcdn.com/48x36/cn.png" alt="中文"></button>
        <button class="flag-btn" onclick="setLang('hi')"><img src="https://flagcdn.com/48x36/in.png" alt="हिन्दी"></button>
        <button class="flag-btn" onclick="setLang('ar')"><img src="https://flagcdn.com/48x36/sa.png" alt="العربية"></button>
        <button class="flag-btn" onclick="setLang('pt')"><img src="https://flagcdn.com/48x36/br.png" alt="Português"></button>
        <button class="flag-btn" onclick="setLang('ru')"><img src="https://flagcdn.com/48x36/ru.png" alt="Русский"></button>
        <button class="flag-btn" onclick="setLang('bn')"><img src="https://flagcdn.com/48x36/bd.png" alt="বাংলা"></button>
        <button class="flag-btn" onclick="setLang('id')"><img src="https://flagcdn.com/48x36/id.png" alt="Indonesia"></button>
      </div>
    </div>
  </div>

  <!-- ═══ PAGE PRINCIPALE ═══ -->
  <div class="container" id="mainContent" style="display:none;">

    <!-- Mini drapeaux (switcher) -->
    <div class="lang-mini-switcher">
      <button class="flag-mini active-flag" id="flag-fr" onclick="setLang('fr')"><img src="https://flagcdn.com/24x18/fr.png" alt="fr"></button>
      <button class="flag-mini" id="flag-en" onclick="setLang('en')"><img src="https://flagcdn.com/24x18/us.png" alt="en"></button>
      <button class="flag-mini" id="flag-es" onclick="setLang('es')"><img src="https://flagcdn.com/24x18/es.png" alt="es"></button>
      <button class="flag-mini" id="flag-zh" onclick="setLang('zh')"><img src="https://flagcdn.com/24x18/cn.png" alt="zh"></button>
      <button class="flag-mini" id="flag-hi" onclick="setLang('hi')"><img src="https://flagcdn.com/24x18/in.png" alt="hi"></button>
      <button class="flag-mini" id="flag-ar" onclick="setLang('ar')"><img src="https://flagcdn.com/24x18/sa.png" alt="ar"></button>
      <button class="flag-mini" id="flag-pt" onclick="setLang('pt')"><img src="https://flagcdn.com/24x18/br.png" alt="pt"></button>
      <button class="flag-mini" id="flag-ru" onclick="setLang('ru')"><img src="https://flagcdn.com/24x18/ru.png" alt="ru"></button>
      <button class="flag-mini" id="flag-bn" onclick="setLang('bn')"><img src="https://flagcdn.com/24x18/bd.png" alt="bn"></button>
      <button class="flag-mini" id="flag-id" onclick="setLang('id')"><img src="https://flagcdn.com/24x18/id.png" alt="id"></button>
    </div>

    <!-- Header -->
    <div class="header">
      <img src="<%= menuImage %>" alt="Menu" class="bot-image" onerror="this.style.display='none'">
      <h1 class="bot-name">🤖 <%= botName %></h1>
      <p class="dev-name">by <%= devName %></p>
    </div>

    <!-- Card connexion -->
    <div class="card">
      <h2 data-i18n="h2_connect">📱 Connecter WhatsApp</h2>
      <p class="subtitle" data-i18n="subtitle_connect">Entre ton numéro avec le code pays pour obtenir ton code de jumelage</p>

      <form id="pairForm">
        <div class="input-group">
          <span class="flag">🌍</span>
          <input type="tel" id="number" placeholder="Ex: 242065121108" maxlength="15" autocomplete="off" inputmode="numeric">
        </div>
        <p class="hint" data-i18n="hint">⚠️ Inclure le code pays sans le + (ex: <strong>242</strong>XXXXXXXX)</p>
        <button id="pairBtn" type="submit" data-i18n="btn_pair">📲 Obtenir mon code</button>
      </form>

      <div id="result" style="display:none;" class="result"></div>

      <div id="codeDisplay" style="display:none;" class="code-box">
        <p class="code-label" data-i18n="code_label">🔑 Ton code de jumelage :</p>
        <div class="code-value" id="codeValue"></div>
        <button id="copyBtn" class="copy-btn" data-i18n="btn_copy">📋 Copier le code</button>
      </div>

      <div id="steps" style="display:none;" class="steps-box">
        <h3 data-i18n="steps_title">📋 Comment entrer le code dans WhatsApp :</h3>
        <ol id="stepsList"></ol>
        <div class="warning-box" data-i18n="warning">⏱️ Le code expire dans <strong>60 secondes</strong> — entre-le rapidement !</div>
      </div>
    </div>

    <!-- Liens sociaux -->
    <div class="social-links">
      <% if (channelLink) { %><a href="<%= channelLink %>" target="_blank" class="social-btn" data-i18n="social_channel">📢 Canal</a><% } %>
      <% if (groupLink) { %><a href="<%= groupLink %>" target="_blank" class="social-btn" data-i18n="social_group">👥 Groupe</a><% } %>
      <% if (telegram) { %><a href="<%= telegram %>" target="_blank" class="social-btn">✈️ Telegram</a><% } %>
    </div>

    <p class="footer" data-i18n="footer">© 2025 <%= devName %> • Tous droits réservés</p>
  </div>

  <script src="/app.js"></script>
</body>
</html>
